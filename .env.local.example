# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Upstash Redis (optional – falls back to in-memory if absent)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI (for pgvector embeddings – generate via store_settings admin panel)
# LLM_API_KEY is read from encrypted store_settings table, not .env

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
